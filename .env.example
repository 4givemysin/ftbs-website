# Resend — contact form email delivery
# Copy to `.env.local` for local development and set in your hosting provider for production.

# Resend API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Verified sender address in Resend (must use a verified domain in production)
# Example: FTBS Website <noreply@ftbsllc.com>
# Resend sandbox for testing: onboarding@resend.dev
RESEND_FROM_EMAIL=FTBS Website <onboarding@resend.dev>

# Internal inbox that receives new contact form submissions
CONTACT_NOTIFICATION_EMAIL=info@ftbsllc.com
